      "nombre": "Programacion de Actividades P/D",
      "modalidad": "individual",
      "clinical_goal": "Incrementar activacion diaria mediante agenda graduada de actividades con puntuacion de placer y dominio",
      "indications": [
        "depresion con inactividad",
        "anhedonia",
        "retirada conductual"
      ],
      "expected_outcomes": [
