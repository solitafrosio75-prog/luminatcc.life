        {
          "orden": 3,
          "accion": "Especificar dia, hora, lugar y senal de inicio",
          "objetivo": "Reducir ambiguedad y facilitar ejecucion"
        },
        {
          "orden": 4,
          "accion": "Ajustar plan en funcion de cumplimiento real",
          "objetivo": "Mantener desafio realista evitando abrumo"
        }
      ],
      "success_criteria": [
